# Configurazione TradeImpact Web - Docker Environment

# Platform/Market Configuration
PLATFORM_ID=1

# IPSP Configuration
IPSP_HOST=your-ipsp-hostname
IPSP_PORT=8800
IPSP_SSL=true

# Database Retention
DATABASE_CLEANUP_RETENTION_DAYS=30

# Logging Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Java Memory
JAVA_OPTS=-Xmx1g -Xms512m
