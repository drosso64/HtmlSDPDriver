# Configurazione TradeImpact Web - Docker Environment

# SDP Server Configuration
SDP_HOST=your-sdp-server-hostname
SDP_PORT=9999
SDP_USERNAME=your-username
SDP_PASSWORD=your-password

# Database Retention
DATA_RETENTION_DAYS=30

# Logging Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Java Memory
JAVA_OPTS=-Xmx1g -Xms512m
