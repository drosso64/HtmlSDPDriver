# ========================================
# Configurazione Proxy per Docker Build
# ========================================
#
# Se sei dietro un proxy aziendale, copia questo file in .env.proxy
# e modifica i valori sotto con le impostazioni del tuo proxy
#
# ESEMPIO:
#   cp .env.proxy.example .env.proxy
#   nano .env.proxy
#

# URL del proxy HTTP
# Formato: http://[username:password@]hostname:port
# Esempio: http://proxy.azienda.com:8080
# Esempio con autenticazione: http://user:pass@proxy.azienda.com:8080
HTTP_PROXY=http://proxy.example.com:8080

# URL del proxy HTTPS (solitamente uguale a HTTP_PROXY)
HTTPS_PROXY=http://proxy.example.com:8080

# Lista di host che NON devono usare il proxy (separati da virgola)
# Tipicamente: localhost, 127.0.0.1, indirizzi interni
NO_PROXY=localhost,127.0.0.1,.local,.internal

# ========================================
# ISTRUZIONI
# ========================================
#
# 1. Copia questo file:
#    cp .env.proxy.example .env.proxy
#
# 2. Modifica .env.proxy con i tuoi valori:
#    nano .env.proxy
#
# 3. Esegui il build:
#    ./docker-build-playwright.sh
#
# 4. Il build userà automaticamente il proxy configurato
#
# ========================================
# TROUBLESHOOTING
# ========================================
#
# Se non sai quale proxy usare, chiedi al tuo IT o prova:
#
# Su Linux/Mac:
#   echo $HTTP_PROXY
#   echo $HTTPS_PROXY
#
# Oppure controlla le impostazioni di sistema:
#   cat /etc/environment
#   env | grep -i proxy
#
# ========================================
